# DiffMaster Configuration
# Copy this file to .env and fill in values

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-to-a-secure-random-string

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://diffmaster:diffmaster@localhost:5432/diffmaster
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- OpenAI (for embeddings & review generation) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096

# --- GitHub Integration ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# --- GitLab Integration ---
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=

# --- Review Settings ---
MAX_COMMENTS_PER_PR=25
COMMENT_DEDUP_ENABLED=true
SUPPRESS_STYLE_ONLY=false
MIN_SEVERITY=INFO

# --- RAG Settings ---
VECTOR_SIMILARITY_THRESHOLD=0.75
RAG_TOP_K=10
EMBEDDING_DIMENSIONS=1536
